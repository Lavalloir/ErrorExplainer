{
  "manifest_version": 3,
  "name": "Error Explainer",
  "version": "1.0",
  "description": "Explique les erreurs Symfony, Laravel, React, PHP, JS en langage simple.",

  "permissions": ["activeTab", "storage", "contextMenus"],
  "host_permissions": ["https://raw.githubusercontent.com/*"],

  "icons": {
    "16":  "icons/icon.png",
    "48":  "icons/icon.png",
    "128": "icons/icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon.png",
      "48":  "icons/icon.png",
      "128": "icons/icon.png"
    }
  },

  "background": {
    "service_worker": "js/background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["errors/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
